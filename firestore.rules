rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: id, name, email, role, branchId, positionId, avatar
    //
    // Collection: inventory
    // Fields: id, managementNumber, partNumber, name, status, carModel, carYear, category, price
    //
    // Collection: collections
    // Fields: id, collectionNumber, customerName, status, collectionDate, totalAmount
    //
    // Collection: branches
    // Fields: id, name, address, phone, managerId
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "herlen0976@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admins can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Only admins can create or update roles. Users can update their own non-sensitive info.
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'worker');
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Simplified for prototype, should be hardened
    }

    match /collections/{collectionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /receipts/{receiptId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
